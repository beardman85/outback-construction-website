# Cloudflare Pages headers — caching + baseline security.
# Astro fingerprints assets in /_astro/, so they can be cached forever.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Optimized images emitted by Astro
/_image
  Cache-Control: public, max-age=31536000, immutable

# Brand logos + static assets (content-stable, moderate cache)
/brand/*
  Cache-Control: public, max-age=604800
/favicon.svg
  Cache-Control: public, max-age=604800
/og-default.png
  Cache-Control: public, max-age=604800

# HTML + everything else: always revalidate so content updates go live immediately
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
