---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---
<nav aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2 text-sm text-white/70">
    {crumbs.map((c, i) => (
      <li class="flex items-center gap-2">
        {c.href ? (
          <a href={c.href} class="hover:text-white">{c.label}</a>
        ) : (
          <span class="text-white" aria-current="page">{c.label}</span>
        )}
        {i < crumbs.length - 1 && <span aria-hidden="true" class="text-white/40">/</span>}
      </li>
    ))}
  </ol>
</nav>
