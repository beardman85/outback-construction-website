---
import business from '../data/business.json';

interface Props {
  heading: string;
  /** Optional supporting paragraph shown under the heading. */
  body?: string;
  /** Show the email address alongside phone (used on the homepage final CTA). */
  showEmail?: boolean;
}

const { heading, body, showEmail = false } = Astro.props;
---
<section class="bg-red-600 text-white">
  <div class="mx-auto max-w-4xl px-4 py-16 text-center lg:px-6">
    <h2 class="font-heading text-2xl font-extrabold tracking-tight sm:text-3xl">{heading}</h2>
    {body && <p class="mx-auto mt-4 max-w-2xl text-red-50">{body}</p>}
    <p class="mt-3 text-sm text-red-100">{business.cta.supportLine}</p>

    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/contact"
        class="w-full rounded-md bg-white px-6 py-3 text-base font-bold text-red-700 shadow-sm transition hover:bg-ink-100 sm:w-auto"
      >
        {business.cta.button}
      </a>
      <a
        href={business.telephoneHref}
        data-phone-cta
        class="w-full rounded-md border-2 border-white px-6 py-3 text-base font-bold text-white transition hover:bg-white/10 sm:w-auto"
      >
        Call {business.telephoneDisplay}
      </a>
    </div>

    {showEmail && (
      <p class="mt-4 text-sm text-red-100">
        <a href={`mailto:${business.email}`} class="underline hover:text-white">{business.email}</a>
      </p>
    )}
  </div>
</section>
