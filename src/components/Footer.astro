---
import business from '../data/business.json';
import services from '../data/services.json';
import locations from '../data/locations.json';

const year = new Date().getFullYear();
const { streetAddress, addressLocality, addressRegion, postalCode } = business.address;
---
<footer class="bg-ink-950 text-white">
  <!-- Brand accent divider (matches the hero bar) -->
  <div class="flex h-1.5" aria-hidden="true">
    <span class="w-1/4 bg-red-600"></span>
    <span class="flex-1 bg-white"></span>
    <span class="w-1/3 bg-red-600"></span>
  </div>
  <div class="mx-auto max-w-7xl px-4 py-14 lg:px-6">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- NAP block (from business.json — never hardcoded) -->
      <div>
        <img src="/brand/logo-white.png" alt={business.name} width="200" height="49" class="h-11 w-auto" />
        <p class="mt-4 max-w-xs text-sm text-ink-300">{business.tagline}</p>
        <address class="mt-4 space-y-1 text-sm not-italic text-ink-300">
          <div>{streetAddress}</div>
          <div>{addressLocality}, {addressRegion} {postalCode}</div>
          <div>
            <a href={business.telephoneHref} data-phone-cta class="font-bold text-white hover:text-red-400">
              {business.telephoneDisplay}
            </a>
          </div>
          <div>
            <a href={`mailto:${business.email}`} class="hover:text-red-400">{business.email}</a>
          </div>
          <div class="pt-1 text-ink-400">{business.hoursDisplay}</div>
        </address>
        {business.sameAs && business.sameAs.length > 0 && (
          <a
            href={business.sameAs[0]}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${business.shortName} on Facebook`}
            class="mt-4 inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/15 text-ink-300 transition hover:border-red-500 hover:text-white"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.5-1.5H17V3.6c-.3 0-1.3-.1-2.4-.1-2.4 0-4.1 1.5-4.1 4.2v2.2H7.6V13h2.9v8h3z" /></svg>
          </a>
        )}
      </div>

      <!-- Services -->
      <nav aria-label="Services">
        <h2 class="text-sm font-bold uppercase tracking-wide text-red-400">Services</h2>
        <ul class="mt-4 space-y-2 text-sm">
          {services.map((s) => (
            <li><a href={`/services/${s.slug}`} class="text-ink-300 hover:text-white">{s.navLabel}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Service Areas -->
      <nav aria-label="Service areas">
        <h2 class="text-sm font-bold uppercase tracking-wide text-red-400">Service Areas</h2>
        <ul class="mt-4 space-y-2 text-sm">
          {locations.filter((l) => !(l as { flagship?: boolean }).flagship).map((l) => (
            <li><a href={`/locations/${l.slug}`} class="text-ink-300 hover:text-white">{l.navLabel}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Company + CTA -->
      <div>
        <nav aria-label="Company">
          <h2 class="text-sm font-bold uppercase tracking-wide text-red-400">Company</h2>
          <ul class="mt-4 space-y-2 text-sm">
            <li><a href="/our-work" class="text-ink-300 hover:text-white">Our Work</a></li>
            <li><a href="/reviews" class="text-ink-300 hover:text-white">Reviews</a></li>
            <li><a href="/about" class="text-ink-300 hover:text-white">About</a></li>
            <li><a href="/contact" class="text-ink-300 hover:text-white">Contact</a></li>
          </ul>
        </nav>
        <a
          href="/contact"
          class="mt-6 inline-block rounded-md bg-red-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-red-700"
        >
          {business.cta.button}
        </a>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-ink-400 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} {business.name}. Owner-operated since {business.foundingYear}. {addressLocality}, {addressRegion}.</p>
      <p>Powered by <a href="https://beardmandesign.com" target="_blank" rel="noopener noreferrer" class="font-semibold text-ink-300 transition hover:text-white">Beardman Design LLC</a></p>
      <div class="flex gap-4">
        <a href="/privacy-policy" class="hover:text-white">Privacy Policy</a>
        <a href="/terms" class="hover:text-white">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
