---
import business from '../data/business.json';
import services from '../data/services.json';
import locations from '../data/locations.json';
---
<header data-site-header class="sticky top-0 z-40 border-b border-white/10 bg-ink-950 text-white transition-shadow duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 lg:px-6">
    <!-- Brand -->
    <a href="/" class="flex items-center" aria-label={`${business.name} — home`}>
      <img
        src="/brand/logo-white.png"
        alt={business.name}
        width="182"
        height="45"
        class="h-10 w-auto lg:h-11"
      />
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden items-center gap-1 lg:flex">
      <a href="/" class="rounded px-3 py-2 text-sm font-semibold hover:text-red-400">Home</a>

      <!-- Services dropdown (CSS-only) -->
      <div class="group relative">
        <a
          href="/services"
          class="flex items-center gap-1 rounded px-3 py-2 text-sm font-semibold hover:text-red-400 group-focus-within:text-red-400"
        >
          Services
          <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true" fill="currentColor"><path d="M2 4l4 4 4-4z" /></svg>
        </a>
        <div class="invisible absolute left-0 top-full z-50 min-w-56 rounded-md border border-ink-200 bg-white p-2 text-ink-900 opacity-0 shadow-xl transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
          {services.map((s) => (
            <a href={`/services/${s.slug}`} class="block rounded px-3 py-2 text-sm font-medium hover:bg-red-50 hover:text-red-700">{s.navLabel}</a>
          ))}
        </div>
      </div>

      <!-- Service Areas dropdown (CSS-only) -->
      <div class="group relative">
        <a
          href="/service-areas"
          class="flex items-center gap-1 rounded px-3 py-2 text-sm font-semibold hover:text-red-400 group-focus-within:text-red-400"
        >
          Service Areas
          <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true" fill="currentColor"><path d="M2 4l4 4 4-4z" /></svg>
        </a>
        <div class="invisible absolute left-0 top-full z-50 min-w-60 rounded-md border border-ink-200 bg-white p-2 text-ink-900 opacity-0 shadow-xl transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
          {locations.map((l) => (
            <a href={`/locations/${l.slug}`} class="block rounded px-3 py-2 text-sm font-medium hover:bg-red-50 hover:text-red-700">{l.navLabel}</a>
          ))}
        </div>
      </div>

      <a href="/our-work" class="rounded px-3 py-2 text-sm font-semibold hover:text-red-400">Our Work</a>
      <a href="/reviews" class="rounded px-3 py-2 text-sm font-semibold hover:text-red-400">Reviews</a>
      <a href="/about" class="rounded px-3 py-2 text-sm font-semibold hover:text-red-400">About</a>
      <a href="/contact" class="rounded px-3 py-2 text-sm font-semibold hover:text-red-400">Contact</a>
    </nav>

    <!-- Header CTA -->
    <div class="hidden items-center gap-3 lg:flex">
      <a href={business.telephoneHref} data-phone-cta class="text-sm font-bold text-white hover:text-red-400">
        {business.telephoneDisplay}
      </a>
      <a
        href="/contact"
        class="rounded-md bg-red-600 px-4 py-2 text-sm font-bold text-white shadow-sm transition hover:bg-red-700"
      >
        {business.cta.button}
      </a>
    </div>

    <!-- Mobile menu toggle (checkbox hack, zero JS) -->
    <input type="checkbox" id="mobile-nav-toggle" class="peer hidden" />
    <label
      for="mobile-nav-toggle"
      class="cursor-pointer rounded p-2 hover:bg-white/10 lg:hidden"
      aria-label="Toggle navigation menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </label>

    <!-- Mobile panel -->
    <nav
      aria-label="Mobile"
      class="absolute left-0 top-full hidden max-h-[80vh] w-full overflow-y-auto border-t border-white/10 bg-ink-950 px-4 py-4 peer-checked:block lg:hidden"
    >
      <a href="/" class="block rounded px-3 py-2 text-sm font-semibold hover:bg-white/10">Home</a>
      <a href="/services" class="block px-3 pb-1 pt-3 text-xs font-bold uppercase tracking-wide text-red-400">Services</a>
      {services.map((s) => (
        <a href={`/services/${s.slug}`} class="block rounded px-3 py-2 text-sm hover:bg-white/10">{s.navLabel}</a>
      ))}
      <a href="/service-areas" class="block px-3 pb-1 pt-3 text-xs font-bold uppercase tracking-wide text-red-400">Service Areas</a>
      {locations.map((l) => (
        <a href={`/locations/${l.slug}`} class="block rounded px-3 py-2 text-sm hover:bg-white/10">{l.navLabel}</a>
      ))}
      <div class="mt-2 border-t border-white/10 pt-2">
        <a href="/our-work" class="block rounded px-3 py-2 text-sm font-semibold hover:bg-white/10">Our Work</a>
        <a href="/reviews" class="block rounded px-3 py-2 text-sm font-semibold hover:bg-white/10">Reviews</a>
        <a href="/about" class="block rounded px-3 py-2 text-sm font-semibold hover:bg-white/10">About</a>
        <a href="/contact" class="block rounded px-3 py-2 text-sm font-semibold hover:bg-white/10">Contact</a>
      </div>
      <div class="mt-3 flex flex-col gap-2">
        <a href={business.telephoneHref} data-phone-cta class="rounded-md border border-white/20 px-4 py-2 text-center text-sm font-bold text-white">
          Call {business.telephoneDisplay}
        </a>
        <a href="/contact" class="rounded-md bg-red-600 px-4 py-2 text-center text-sm font-bold text-white hover:bg-red-700">
          {business.cta.button}
        </a>
      </div>
    </nav>
  </div>
</header>
