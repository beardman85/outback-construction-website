---
import { getImage } from 'astro:assets';
import { jobs } from '../data/jobs';
import services from '../data/services.json';

const jobImages = import.meta.glob<{ default: ImageMetadata }>('../assets/jobs/*.jpg', { eager: true });
const labelFor = (slug: string) => services.find((s) => s.slug === slug)?.navLabel ?? 'Marine construction';

// Build client-ready data with optimized popup thumbnails.
const clientJobs = await Promise.all(
  jobs.map(async (j) => {
    const meta = jobImages[`../assets/jobs/job-${j.id}.jpg`].default;
    const thumb = await getImage({ src: meta, width: 480, format: 'webp' });
    return { lat: j.lat, lng: j.lng, title: j.title, service: labelFor(j.service), community: j.community, thumb: thumb.src };
  })
);

// Unique communities, for a scannable (and SEO-friendly) list.
const communities = [...new Set(jobs.map((j) => j.community))];
---
<section class="bg-ink-950 text-white">
  <div class="mx-auto max-w-7xl px-4 py-16 lg:px-6">
    <div class="max-w-2xl">
      <p class="flex items-center gap-2 text-sm font-bold uppercase tracking-[0.2em] text-red-500">
        <span class="inline-block h-px w-8 bg-red-500"></span>
        Project map
      </p>
      <h2 class="mt-3 font-heading text-2xl font-extrabold tracking-tight sm:text-3xl">
        Where we've built — {jobs.length} recent shoreline projects
      </h2>
      <p class="mt-4 text-ink-200">
        Every pin is a real Outback project across Southeast Nebraska's lake communities. Click one to see the work.
      </p>
    </div>

    <div class="mt-6 flex flex-wrap gap-2">
      {communities.map((c) => (
        <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-ink-100">{c}</span>
      ))}
    </div>

    <div id="project-map" class="mt-8 h-[520px] w-full overflow-hidden rounded-2xl border border-white/10 shadow-2xl"></div>
    <script type="application/json" id="project-jobs" set:html={JSON.stringify(clientJobs)}></script>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  const el = document.getElementById('project-map');
  const dataEl = document.getElementById('project-jobs');
  if (el && dataEl) {
    const jobs = JSON.parse(dataEl.textContent || '[]');
    const map = L.map(el, { scrollWheelZoom: false });
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
      maxZoom: 19,
    }).addTo(map);

    const icon = L.divIcon({
      className: 'ob-pin',
      html: '<svg width="28" height="38" viewBox="0 0 28 38" xmlns="http://www.w3.org/2000/svg"><path d="M14 0C6.3 0 0 6.3 0 14c0 9.8 14 24 14 24s14-14.2 14-24C28 6.3 21.7 0 14 0z" fill="#ce0202" stroke="#fff" stroke-width="1.5"/><circle cx="14" cy="14" r="5" fill="#fff"/></svg>',
      iconSize: [28, 38],
      iconAnchor: [14, 38],
      popupAnchor: [0, -34],
    });

    const bounds: [number, number][] = [];
    jobs.forEach((j: any) => {
      const m = L.marker([j.lat, j.lng], { icon }).addTo(map);
      m.bindPopup(
        `<div style="width:220px;font-family:system-ui,sans-serif">
           <img src="${j.thumb}" alt="" style="width:100%;height:130px;object-fit:cover;border-radius:6px;display:block" loading="lazy">
           <div style="font-weight:700;color:#111;margin-top:8px;line-height:1.3">${j.title}</div>
           <div style="color:#ce0202;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.05em;margin-top:4px">${j.service}</div>
           <div style="color:#555;font-size:13px;margin-top:2px">📍 ${j.community}</div>
         </div>`,
        { maxWidth: 240 }
      );
      bounds.push([j.lat, j.lng]);
    });
    if (bounds.length) map.fitBounds(bounds, { padding: [40, 40] });
  }
</script>
