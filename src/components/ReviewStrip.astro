---
import business from '../data/business.json';
import reviews from '../data/reviews.json';

interface Props {
  heading?: string;
}
const { heading = 'What lake homeowners say' } = Astro.props;
---
<section class="bg-ink-50">
  <div class="mx-auto max-w-7xl px-4 py-20 lg:px-6">
    <div data-reveal class="flex flex-col items-center gap-3 text-center">
      <h2 class="font-heading text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">{heading}</h2>
      <div class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-4 py-1.5 shadow-sm">
        <span class="text-red-600" aria-hidden="true">★★★★★</span>
        <span class="text-sm font-bold text-ink-800">{business.rating.displayText}</span>
      </div>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {reviews.featured.map((r, i) => (
        <figure
          data-reveal
          style={`--reveal-delay:${i * 90}ms`}
          class="group relative flex h-full flex-col rounded-2xl border border-ink-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:border-red-200 hover:shadow-xl"
        >
          <span aria-hidden="true" class="pointer-events-none absolute right-6 top-4 font-heading text-6xl leading-none text-red-600/15 transition group-hover:text-red-600/25">&rdquo;</span>
          <span class="text-red-600" aria-hidden="true">★★★★★</span>
          <blockquote class="mt-4 flex-1 text-ink-700">
            <p>&ldquo;{r.quote}&rdquo;</p>
          </blockquote>
          <figcaption class="mt-6 flex items-center gap-3 border-t border-ink-100 pt-4">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-ink-950 text-sm font-bold text-white">
              {r.author.charAt(0)}
            </span>
            <span class="text-sm font-bold text-ink-900">{r.author}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div data-reveal class="mt-10 text-center">
      <a href="/reviews" class="inline-flex items-center gap-1 font-bold text-red-600 hover:text-red-700">
        Read more reviews <span>→</span>
      </a>
    </div>
  </div>
</section>
