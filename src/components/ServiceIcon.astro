---
/**
 * ServiceIcon.astro — brand line-icons keyed by service slug.
 * Uses currentColor so callers control the color via text-*.
 */
interface Props {
  slug: string;
  class?: string;
}
const { slug, class: className = 'h-7 w-7' } = Astro.props;

const common = {
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '1.75',
  'stroke-linecap': 'round' as const,
  'stroke-linejoin': 'round' as const,
  'aria-hidden': 'true',
};
---
{slug === 'boat-docks' && (
  <svg class={className} {...common}>
    <path d="M2 13h20" />
    <path d="M6 13v6M12 13v6M18 13v6" />
    <path d="M2 20c1.4 0 1.4-1 2.8-1s1.4 1 2.8 1 1.4-1 2.8-1 1.4 1 2.8 1 1.4-1 2.8-1 1.4 1 2.8 1" />
    <path d="M15 9l4-2-1 3" />
  </svg>
)}
{slug === 'seawalls' && (
  <svg class={className} {...common}>
    <path d="M2 8c1.5 0 1.5-1.5 3-1.5S6.5 8 8 8s1.5-1.5 3-1.5S12.5 8 14 8s1.5-1.5 3-1.5S18.5 8 20 8" />
    <rect x="3" y="11" width="18" height="10" rx="1" />
    <path d="M3 16h18M9 11v5M15 11v5M6 16v5M12 16v5M18 16v5" />
  </svg>
)}
{slug === 'retaining-walls' && (
  <svg class={className} {...common}>
    <path d="M3 20h18" />
    <path d="M3 20L14 9" />
    <rect x="14" y="5" width="7" height="15" rx="0.5" />
    <path d="M14 10h7M14 15h7" />
  </svg>
)}
{slug === 'barge-work' && (
  <svg class={className} {...common}>
    <path d="M2 16h18l-2 3.5H4z" />
    <path d="M7 16V6h2" />
    <path d="M9 6l7 4" />
    <path d="M14 9v3" />
    <path d="M2 21c1.4 0 1.4-1 2.8-1s1.4 1 2.8 1" />
  </svg>
)}
{slug === 'beach-reclamation' && (
  <svg class={className} {...common}>
    <circle cx="12" cy="8" r="3" />
    <path d="M12 2v1M12 13v1M5 8H4M20 8h-1M6.5 2.5l.8.8M17.5 2.5l-.8.8" />
    <path d="M2 19c1.6 0 1.6-1.2 3.2-1.2S6.8 19 8.4 19s1.6-1.2 3.2-1.2S13.2 19 14.8 19s1.6-1.2 3.2-1.2S19.6 19 22 19" />
    <path d="M2 22h20" />
  </svg>
)}
