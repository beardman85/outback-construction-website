---
import '../styles/global.css';
import business from '../data/business.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';

interface Props {
  title: string;
  description: string;
  /** Path for canonical/OG (defaults to current URL). e.g. "/services/seawalls" */
  canonicalPath?: string;
  noindex?: boolean;
  ogImage?: string;
  /** Page-specific JSON-LD nodes merged into the site @graph. */
  schemaGraph?: Record<string, unknown>[];
}

const {
  title,
  description,
  canonicalPath,
  noindex = false,
  ogImage = '/og-default.jpg',
  schemaGraph = [],
} = Astro.props;

const canonicalURL = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// GTM container — loads GTM + Consent Mode v2 + phone-click / generate_lead events.
// GA4 (G-TQB6PSPEKT) is configured inside GTM, not here.
const GTM_ID = 'GTM-N3986WW9';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Museo Sans via Adobe Fonts (licensed). Kit: hzs6raj. Loaded async so it
         never blocks render — the fallback stack shows first, Museo swaps in. -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="preconnect" href="https://p.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/hzs6raj.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://use.typekit.net/hzs6raj.css" /></noscript>
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Geo (local SEO) -->
    <meta name="geo.region" content={`US-${business.address.addressRegion}`} />
    <meta name="geo.placename" content={`${business.address.addressLocality}, ${business.address.addressRegion}`} />
    <meta name="geo.position" content={`${business.geo.latitude};${business.geo.longitude}`} />
    <meta name="ICBM" content={`${business.geo.latitude}, ${business.geo.longitude}`} />

    {/* Consent Mode v2 defaults MUST run before GTM. Only injected when a container ID is set. */}
    {GTM_ID && (
      <script is:inline set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('consent', 'default', {
          ad_storage: 'granted',
          ad_user_data: 'granted',
          ad_personalization: 'granted',
          analytics_storage: 'granted'
        });
      `} />
    )}
    {GTM_ID && (
      <script is:inline set:html={`
        (function(w,d,s,l,i){
          function load(){
            if (w.__gtmLoaded) return; w.__gtmLoaded = 1;
            w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
            var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
            j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          }
          // Defer GTM off the critical render path: load on the first user
          // interaction, or shortly after the page settles — whichever comes
          // first. dataLayer events queued before this fire once GTM loads.
          var evts=['scroll','click','keydown','touchstart','pointerdown'];
          function onFirst(){ evts.forEach(function(e){w.removeEventListener(e,onFirst)}); load(); }
          evts.forEach(function(e){w.addEventListener(e,onFirst,{once:true,passive:true})});
          w.addEventListener('load', function(){ setTimeout(load, 1800); });
        })(window,document,'script','dataLayer','${GTM_ID}');
      `} />
    )}

    <Schema graph={schemaGraph} />

    {/* Per-page head extras, e.g. an LCP image preload (see homepage hero). */}
    <slot name="head" />

    {/* No-JS + crawler fallback: never hide content behind the reveal animation. */}
    <noscript set:html={`<style>[data-reveal]{opacity:1 !important;transform:none !important;}</style>`} />
  </head>
  <body class="min-h-screen bg-white text-ink-900 antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-red-600 focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    {GTM_ID && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}

    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {/* Phone-click conversion tracking (spec rule #6). Minimal, only when GTM is live. */}
    {GTM_ID && (
      <script is:inline set:html={`
        document.addEventListener('click', function (e) {
          var link = e.target.closest && e.target.closest('a[data-phone-cta]');
          if (link) { window.dataLayer.push({ event: 'phone_call_click' }); }
        });
      `} />
    )}

    {/* Motion system: scroll-reveal, count-up stats, header-on-scroll. Vanilla, ~1KB. */}
    <script is:inline>
      (function () {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var hasIO = 'IntersectionObserver' in window;

        // Scroll reveal
        var reveals = document.querySelectorAll('[data-reveal]');
        if (reduce || !hasIO) {
          reveals.forEach(function (el) { el.classList.add('is-visible'); });
        } else {
          var ro = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { e.target.classList.add('is-visible'); ro.unobserve(e.target); }
            });
          }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
          reveals.forEach(function (el) { ro.observe(el); });
        }

        // Count-up stats
        function countUp(el) {
          var target = parseFloat(el.getAttribute('data-countup')) || 0;
          var dec = parseInt(el.getAttribute('data-decimals') || '0', 10);
          var suffix = el.getAttribute('data-suffix') || '';
          var prefix = el.getAttribute('data-prefix') || '';
          if (reduce) { el.textContent = prefix + target.toFixed(dec) + suffix; return; }
          var dur = 1500, start = null;
          function step(ts) {
            if (!start) start = ts;
            var p = Math.min((ts - start) / dur, 1);
            var eased = 1 - Math.pow(1 - p, 3);
            el.textContent = prefix + (target * eased).toFixed(dec) + suffix;
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }
        var counters = document.querySelectorAll('[data-countup]');
        if (hasIO) {
          var co = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) { if (e.isIntersecting) { countUp(e.target); co.unobserve(e.target); } });
          }, { threshold: 0.6 });
          counters.forEach(function (el) { co.observe(el); });
        } else {
          counters.forEach(countUp);
        }

        // Header shadow on scroll
        var header = document.querySelector('[data-site-header]');
        if (header) {
          var onScroll = function () { header.classList.toggle('is-scrolled', window.scrollY > 16); };
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
        }
      })();
    </script>
  </body>
</html>
