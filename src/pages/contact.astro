---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import business from '../data/business.json';
import locations from '../data/locations.json';
import pierSunset from '../assets/pier-sunset.jpg';

const title = 'Contact Outback Construction | Get a Shoreline Assessment | (402) 456-7968';
const description =
  "Tell us what's going on with your waterfront. You'll get a call back from Matt — a straight assessment and a real number. Serving Omaha & SE Nebraska lakes.";

const { streetAddress, addressLocality, addressRegion, postalCode } = business.address;
const mapSrc = `https://maps.google.com/maps?q=${encodeURIComponent(`${streetAddress}, ${addressLocality}, ${addressRegion} ${postalCode}`)}&z=11&output=embed`;

const inputClass =
  'mt-1.5 w-full rounded-lg border border-ink-200 bg-white px-4 py-3 text-ink-900 shadow-sm transition placeholder:text-ink-300 focus:border-red-600 focus:outline-none focus:ring-2 focus:ring-red-600/30';
const checkClass = 'h-4 w-4 flex-none accent-red-600';

const services = ['Seawalls', 'Barge Work', 'Beach Reclamation', 'Retaining Walls', 'Commercial', 'Dock Install/Repair'];
const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
const times = ['Morning', 'Afternoon', 'Evening'];
// TODO[MATT]: confirm budget ranges + "how did you hear" options.
const budgets = ['Not sure yet', 'Under $2,500', '$2,500 – $5,000', '$5,000 – $10,000', '$10,000 – $25,000', '$25,000+'];
const hearAbout = ['Google search', 'Google Maps', 'Facebook / social media', 'Referral / word of mouth', 'Saw your work at a lake', 'Other'];
---
<Base title={title} description={description} canonicalPath="/contact">
  <!-- ================= HERO ================= -->
  <section class="relative isolate flex min-h-[40vh] items-end overflow-hidden bg-ink-950 text-white">
    <Image src={pierSunset} alt="" aria-hidden="true" class="absolute inset-0 -z-20 h-full w-full object-cover opacity-70" widths={[768, 1200, 1600]} sizes="100vw" loading="eager" fetchpriority="high" />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink-950 via-ink-950/80 to-ink-950/40"></div>
    <div class="mx-auto w-full max-w-7xl px-4 py-14 lg:px-6 lg:py-16">
      <p class="flex items-center gap-2 text-sm font-bold uppercase tracking-[0.2em] text-red-500">
        <span class="inline-block h-px w-8 bg-red-500"></span>
        Contact
      </p>
      <h1 class="mt-3 font-heading text-4xl font-extrabold leading-tight tracking-tight drop-shadow sm:text-5xl">
        Get a Shoreline Assessment
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-100">
        Tell us what's going on with your waterfront — or what you want it to become. You'll get a
        call back from Matt, a straight assessment, and a real number. No pressure, no runaround.
      </p>
    </div>
  </section>

  <!-- ================= FORM + INFO ================= -->
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 lg:px-6">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Form -->
        <div class="lg:col-span-3">
          <p data-form-error class="mb-6 hidden rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700">
            Please check the required fields and try again.
          </p>

          <form action="/api/lead" method="POST" enctype="multipart/form-data" data-lead-form class="rounded-2xl border border-ink-200 bg-white p-6 shadow-sm sm:p-8">
            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true"><label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label></div>

            <div>
              <label for="name" class="text-sm font-bold text-ink-900">Full name <span class="text-red-600">*</span></label>
              <input id="name" name="name" type="text" required autocomplete="name" class={inputClass} />
            </div>

            <div class="mt-5 grid gap-5 sm:grid-cols-2">
              <div>
                <label for="phone" class="text-sm font-bold text-ink-900">Phone <span class="text-red-600">*</span></label>
                <div class="mt-1.5 flex items-stretch overflow-hidden rounded-lg border border-ink-200 shadow-sm focus-within:border-red-600 focus-within:ring-2 focus-within:ring-red-600/30">
                  <span class="flex items-center border-r border-ink-200 bg-ink-50 px-3 text-sm font-semibold text-ink-500">+1</span>
                  <input id="phone" name="phone" type="tel" required autocomplete="tel" placeholder="000 000 0000" class="w-full bg-white px-4 py-3 text-ink-900 placeholder:text-ink-300 focus:outline-none" />
                </div>
              </div>
              <div>
                <label for="email" class="text-sm font-bold text-ink-900">Email <span class="text-red-600">*</span></label>
                <input id="email" name="email" type="email" required autocomplete="email" placeholder="example@domain.com" class={inputClass} />
              </div>
            </div>

            <div class="mt-5 grid gap-5 sm:grid-cols-2">
              <div>
                <label for="address" class="text-sm font-bold text-ink-900">Address</label>
                <input id="address" name="address" type="text" autocomplete="street-address" class={inputClass} />
              </div>
              <div>
                <label for="city" class="text-sm font-bold text-ink-900">City / lake</label>
                <input id="city" name="city" type="text" class={inputClass} />
              </div>
            </div>

            <!-- Services -->
            <fieldset class="mt-8">
              <legend class="text-sm font-bold text-ink-900">What services are you interested in? <span class="text-red-600">*</span></legend>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                {services.map((s) => (
                  <label class="flex items-center gap-2.5 text-ink-700">
                    <input type="checkbox" name="services" value={s} class={checkClass} />
                    {s}
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Days -->
            <fieldset class="mt-8">
              <legend class="text-sm font-bold text-ink-900">What days are best to reach you?</legend>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                {days.map((d) => (
                  <label class="flex items-center gap-2.5 text-ink-700">
                    <input type="checkbox" name="days" value={d} class={checkClass} />
                    {d}
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Times -->
            <fieldset class="mt-8">
              <legend class="text-sm font-bold text-ink-900">What time works best?</legend>
              <div class="mt-3 flex flex-wrap gap-x-8 gap-y-3">
                {times.map((t) => (
                  <label class="flex items-center gap-2.5 text-ink-700">
                    <input type="checkbox" name="times" value={t} class={checkClass} />
                    {t}
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="mt-8 grid gap-5 sm:grid-cols-2">
              <div>
                <label for="budget" class="text-sm font-bold text-ink-900">Project budget</label>
                <select id="budget" name="budget" class={inputClass}>
                  <option value="">Select a range…</option>
                  {budgets.map((b) => <option value={b}>{b}</option>)}
                </select>
              </div>
              <div>
                <label for="hearAbout" class="text-sm font-bold text-ink-900">How did you hear about us?</label>
                <select id="hearAbout" name="hearAbout" class={inputClass}>
                  <option value="">Select…</option>
                  {hearAbout.map((h) => <option value={h}>{h}</option>)}
                </select>
              </div>
            </div>

            <div class="mt-5">
              <label for="message" class="text-sm font-bold text-ink-900">Briefly describe your project</label>
              <textarea id="message" name="message" rows="5" placeholder="What's going on with your shoreline — or what you want it to become?" class={inputClass}></textarea>
            </div>

            <div class="mt-5">
              <label for="file" class="text-sm font-bold text-ink-900">Upload files <span class="font-normal text-ink-500">(plans, photos, ideas — optional)</span></label>
              <input id="file" name="file" type="file" accept="image/*,.pdf,.heic" class="mt-1.5 w-full rounded-lg border border-dashed border-ink-300 bg-ink-50 px-4 py-3 text-sm text-ink-700 file:mr-4 file:rounded-md file:border-0 file:bg-red-600 file:px-4 file:py-2 file:font-bold file:text-white hover:file:bg-red-700" />
              <p class="mt-1 text-xs text-ink-500">One file, up to 10&nbsp;MB. Images or PDF.</p>
            </div>

            <label class="mt-6 flex items-start gap-3 text-sm text-ink-700">
              <input type="checkbox" name="agree" required class="mt-0.5 h-4 w-4 flex-none accent-red-600" />
              <span>I've read and agree to the <a href="/terms" class="ob-link">Terms of Service</a> and <a href="/privacy-policy" class="ob-link">Privacy Policy</a>.</span>
            </label>

            <button type="submit" class="mt-6 w-full rounded-lg bg-red-600 px-6 py-3.5 text-base font-bold text-white shadow-sm transition hover:bg-red-700 sm:w-auto">
              {business.cta.button}
            </button>
            <p class="mt-3 text-sm text-ink-500">{business.cta.supportLine}</p>
            <p data-form-status role="status" aria-live="polite" class="mt-4 hidden text-sm font-semibold"></p>
          </form>
        </div>

        <!-- Direct + map -->
        <aside class="lg:col-span-2">
          <div class="rounded-2xl border border-ink-200 bg-ink-50 p-6 sm:p-8">
            <h2 class="font-heading text-xl font-extrabold text-ink-900">Talk to Matt directly</h2>
            <dl class="mt-5 space-y-4 text-ink-700">
              <div>
                <dt class="text-xs font-bold uppercase tracking-wide text-ink-500">Phone</dt>
                <dd><a href={business.telephoneHref} data-phone-cta class="text-lg font-bold text-red-600 hover:text-red-700">{business.telephoneDisplay}</a></dd>
              </div>
              <div>
                <dt class="text-xs font-bold uppercase tracking-wide text-ink-500">Email</dt>
                <dd><a href={`mailto:${business.email}`} class="font-semibold text-ink-900 hover:text-red-600">{business.email}</a></dd>
              </div>
              <div>
                <dt class="text-xs font-bold uppercase tracking-wide text-ink-500">Based in</dt>
                <dd>{addressLocality}, {addressRegion} — serving Omaha &amp; Southeast Nebraska lakes</dd>
              </div>
            </dl>
            <div class="mt-6 overflow-hidden rounded-xl border border-ink-200">
              <iframe title="Map of Outback Construction's service area" src={mapSrc} loading="lazy" referrerpolicy="no-referrer-when-downgrade" class="aspect-video w-full border-0"></iframe>
            </div>
            <div class="mt-6">
              <p class="text-xs font-bold uppercase tracking-wide text-ink-500">Service areas</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {locations.map((l) => (
                  <a href={`/locations/${l.slug}`} class="rounded-full border border-ink-200 bg-white px-3 py-1.5 text-sm font-semibold text-ink-800 transition hover:border-red-600 hover:text-red-600">{l.navLabel}</a>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var form = document.querySelector('[data-lead-form]');
      if (!form) return;
      var status = form.querySelector('[data-form-status]');
      var errBanner = document.querySelector('[data-form-error]');

      // Show a banner if the server bounced a no-JS submission back.
      if (new URLSearchParams(location.search).get('error') && errBanner) errBanner.classList.remove('hidden');

      function fail(msg) {
        if (status) { status.className = 'mt-4 text-sm font-semibold text-red-600'; status.textContent = msg; }
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        // Client checks the group requirements the browser can't.
        var services = form.querySelectorAll('input[name=services]:checked').length;
        var agree = form.querySelector('input[name=agree]').checked;
        if (services < 1) { fail('Please choose at least one service.'); return; }
        if (!agree) { fail('Please agree to the Terms and Privacy Policy.'); return; }

        var btn = form.querySelector('button[type=submit]');
        if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
        if (status) { status.className = 'mt-4 text-sm font-semibold text-ink-500'; status.textContent = ''; }

        fetch('/api/lead', { method: 'POST', headers: { accept: 'application/json' }, body: new FormData(form) })
          .then(function (r) { return r.ok ? r.json() : Promise.reject(r); })
          .then(function () { window.location.href = '/thank-you'; })
          .catch(function () {
            if (btn) { btn.disabled = false; btn.textContent = 'Get a Shoreline Assessment'; }
            fail('Something went wrong. Please call Matt at (402) 456-7968 or try again.');
          });
      });
    })();
  </script>
</Base>
