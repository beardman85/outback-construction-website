---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import CTABlock from '../../components/CTABlock.astro';
import ReviewStrip from '../../components/ReviewStrip.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServiceIcon from '../../components/ServiceIcon.astro';
import business from '../../data/business.json';
import services from '../../data/services.json';
import locations from '../../data/locations.json';
import { locationContent } from '../../data/location-content';
import heroDock from '../../assets/hero-dock.jpg';
import dockBoat from '../../assets/dock-boat.jpg';
import dockDawn from '../../assets/dock-dawn.jpg';
import lakehomeDusk from '../../assets/lakehome-dusk.jpg';
import pierSunset from '../../assets/pier-sunset.jpg';
import lakeSunset from '../../assets/lake-sunset.png';

export function getStaticPaths() {
  return locations.map((l) => ({ params: { city: l.slug }, props: { location: l } }));
}

const { location } = Astro.props;
const content = locationContent[location.slug];

// Vary hero imagery so no two location pages look identical.
const heroImages: Record<string, ImageMetadata> = {
  omaha: dockBoat,
  valley: heroDock,
  waterloo: dockDawn,
  fremont: lakehomeDusk,
  bennington: pierSunset,
  springfield: lakeSunset,
  plattsmouth: heroDock,
};
const heroImg = heroImages[location.slug] ?? heroDock;

const pageUrl = `${business.url}/locations/${location.slug}`;
const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: business.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${business.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: location.navLabel, item: pageUrl },
  ],
};

const trustItems = ['Since 1999', '★ 5.0 on Google', 'Licensed & Insured', 'Owner-Operated'];
// TODO[MATT]: keyless Google Maps embed centered on the town. Refine to specific
// lake communities once named, or swap to the Maps Embed API with a key.
const mapSrc = `https://maps.google.com/maps?q=${encodeURIComponent(content.mapQuery)}&z=11&output=embed`;
const neighbors = content.neighbors
  .map((slug) => locations.find((l) => l.slug === slug))
  .filter(Boolean) as typeof locations;
---
<Base
  title={location.metaTitle}
  description={content.metaDescription}
  canonicalPath={`/locations/${location.slug}`}
  schemaGraph={[breadcrumb]}
>
  <!-- ================= HERO ================= -->
  <section class="relative isolate flex min-h-[55vh] items-end overflow-hidden bg-ink-950 text-white">
    <Image
      src={heroImg}
      alt={`Lakefront marine construction in ${location.navLabel}, Nebraska by Outback Construction`}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      widths={[768, 1200, 1600]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink-950 via-ink-950/70 to-ink-950/30"></div>
    <div class="mx-auto w-full max-w-7xl px-4 py-14 lg:px-6 lg:py-20">
      <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Service Areas', href: '/service-areas' }, { label: location.navLabel }]} />
      <p class="mt-6 flex items-center gap-2 text-sm font-bold uppercase tracking-[0.2em] text-red-500">
        <span class="inline-block h-px w-8 bg-red-500"></span>
        Service Area
      </p>
      <h1 class="mt-3 max-w-3xl font-heading text-4xl font-extrabold leading-[1.08] tracking-tight drop-shadow sm:text-5xl">
        {location.h1}
      </h1>
      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <a href="/contact" class="rounded-md bg-red-600 px-6 py-3 text-center text-base font-bold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-red-700">
          {business.cta.button}
        </a>
        <a href={business.telephoneHref} data-phone-cta class="rounded-md border-2 border-white/70 px-6 py-3 text-center text-base font-bold text-white transition hover:bg-white/10">
          Call Matt: {business.telephoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- ================= TRUST BAR ================= -->
  <div class="border-b border-white/10 bg-ink-950">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-x-6 gap-y-2 px-4 py-4 text-sm font-semibold text-white lg:px-6">
      {trustItems.map((item) => <span>{item}</span>)}
    </div>
  </div>

  <!-- ================= BODY + MAP ================= -->
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 lg:px-6">
      <div class="grid gap-12 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <div class="space-y-5 text-lg text-ink-700">
            {content.paragraphs.map((p) => <p data-reveal set:html={p} />)}
          </div>
          {/* Local FAQs are pending the owner's local knowledge. */}
          <Fragment set:html={`<!-- TODO[MATT]: local FAQs — ${content.localFaqTodo} -->`} />
        </div>

        <aside class="lg:col-span-1">
          <div class="lg:sticky lg:top-24">
            <div class="overflow-hidden rounded-2xl border border-ink-200 shadow-lg">
              <iframe
                title={`Map of the ${location.navLabel}, Nebraska service area`}
                src={mapSrc}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                class="aspect-[4/5] w-full border-0"
              ></iframe>
              <div class="bg-ink-950 p-5 text-white">
                <p class="text-sm text-ink-300">Based in {business.address.addressLocality}, {business.address.addressRegion} — serving {location.navLabel} and the surrounding lakes.</p>
                <a href="/contact" class="mt-4 block rounded-md bg-red-600 px-4 py-3 text-center text-sm font-bold text-white transition hover:bg-red-700">
                  {business.cta.button}
                </a>
                <a href={business.telephoneHref} data-phone-cta class="mt-3 block text-center text-sm font-bold text-white hover:text-red-500">
                  {business.telephoneDisplay}
                </a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ================= SERVICES IN THIS AREA ================= -->
  <section class="bg-ink-50">
    <div class="mx-auto max-w-7xl px-4 py-16 lg:px-6">
      <h2 data-reveal class="font-heading text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">
        Marine services in {location.navLabel}
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s, i) => (
          <a
            href={`/services/${s.slug}`}
            data-reveal
            style={`--reveal-delay:${i * 70}ms`}
            class="group relative flex flex-col overflow-hidden rounded-xl border border-ink-200 bg-white p-6 transition hover:-translate-y-1 hover:border-red-600 hover:shadow-xl"
          >
            <span class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-red-600 transition-transform duration-300 group-hover:scale-x-100"></span>
            <span class="flex h-14 w-14 items-center justify-center rounded-lg bg-ink-950 text-red-500 transition group-hover:bg-red-600 group-hover:text-white">
              <ServiceIcon slug={s.slug} class="h-7 w-7" />
            </span>
            <h3 class="mt-5 font-heading text-xl font-bold text-ink-900">{s.cardTitle}</h3>
            <p class="mt-3 flex-1 text-ink-700">{s.cardBlurb}</p>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-bold text-red-600">
              Learn more <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))}
      </div>

      {neighbors.length > 0 && (
        <div data-reveal class="mt-12 flex flex-wrap items-center gap-3 border-t border-ink-200 pt-8">
          <span class="text-sm font-bold uppercase tracking-wide text-ink-500">Also serving nearby</span>
          {neighbors.map((n) => (
            <a href={`/locations/${n.slug}`} class="rounded-full border border-ink-200 bg-white px-4 py-2 text-sm font-bold text-ink-800 transition hover:border-red-600 hover:bg-red-600 hover:text-white">
              {n.navLabel} →
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ================= REVIEWS ================= -->
  <ReviewStrip />

  <!-- ================= CTA ================= -->
  <CTABlock
    heading="Storm damage? Spring inspection? Planning ahead?"
    body="Get experienced eyes on your shoreline before a small problem becomes a big one."
  />
</Base>
