---
import Base from '../layouts/Base.astro';
import business from '../data/business.json';
const { streetAddress, addressLocality, addressRegion, postalCode } = business.address;
---
<Base title="Privacy Policy | Outback Construction" description="How Outback Construction collects, uses, and protects the information you share with us." canonicalPath="/privacy-policy">
  <Fragment set:html={`<!-- TODO[MATT]: general template — have this reviewed by an attorney and set the effective date before launch. -->`} />
  <section class="bg-white">
    <div class="mx-auto max-w-3xl px-4 py-16 lg:px-6">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-red-600">Privacy Policy</p>
      <h1 class="mt-2 font-heading text-4xl font-extrabold tracking-tight text-ink-900">Your privacy</h1>
      <p class="mt-2 text-sm text-ink-500">Last updated: July 2026</p>

      <div class="mt-8 space-y-8 text-ink-700">
        <p>{business.name} ("Outback Construction," "we," "us") is a marine construction contractor based in {addressLocality}, {addressRegion}. This policy explains what information we collect through this website and how we use it.</p>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">Information we collect</h2>
          <p class="mt-3">When you submit our contact or assessment form, we collect the details you provide — such as your name, phone number, email, address or lake, the services you're interested in, your project description and budget, contact preferences, and any files you upload. We may also collect basic, non-identifying usage data (such as pages visited) when website analytics are enabled.</p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">How we use it</h2>
          <p class="mt-3">We use your information to respond to your inquiry, provide assessments and quotes, schedule and perform work, and communicate with you about your project. We do not sell your personal information.</p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">Sharing</h2>
          <p class="mt-3">We share information only with service providers that help us operate — for example, our email/hosting providers — and when required by law. Our website may load a map from Google and, when enabled, use Google Analytics with consent controls; those services are governed by Google's own policies.</p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">Your choices</h2>
          <p class="mt-3">You may contact us at any time to ask what information we hold, or to request that we correct or delete it. To make a request, use the contact details below.</p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">Contact us</h2>
          <p class="mt-3">
            {business.name}<br />
            {streetAddress}, {addressLocality}, {addressRegion} {postalCode}<br />
            <a href={business.telephoneHref} data-phone-cta class="ob-link">{business.telephoneDisplay}</a> ·
            <a href={`mailto:${business.email}`} class="ob-link">{business.email}</a>
          </p>
        </div>

        <p class="text-sm text-ink-500">We may update this policy from time to time. Continued use of the site means you accept the current version.</p>
      </div>
    </div>
  </section>
</Base>
