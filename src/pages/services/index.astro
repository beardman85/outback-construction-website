---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import CTABlock from '../../components/CTABlock.astro';
import ReviewStrip from '../../components/ReviewStrip.astro';
import ServiceIcon from '../../components/ServiceIcon.astro';
import business from '../../data/business.json';
import services from '../../data/services.json';
import heroDock from '../../assets/hero-dock.jpg';

const title = 'Marine Construction Services | Docks, Seawalls & Beaches | Outback';
// TODO[MATT]: review this meta description (content.md gave no /services index copy).
const description =
  'Boat docks, seawalls, retaining walls, barge work & beach reclamation for Nebraska lakefront properties. Owner-operated marine construction since 1999.';

const pageUrl = `${business.url}/services`;
const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: business.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: pageUrl },
  ],
};
---
<Base title={title} description={description} canonicalPath="/services" schemaGraph={[breadcrumb]}>
  <section class="relative isolate flex min-h-[45vh] items-end overflow-hidden bg-ink-950 text-white">
    <Image src={heroDock} alt="Marine construction on a Southeast Nebraska lake by Outback Construction" class="absolute inset-0 -z-20 h-full w-full object-cover" widths={[768, 1200, 1600]} sizes="100vw" loading="eager" fetchpriority="high" />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink-950 via-ink-950/70 to-ink-950/30"></div>
    <div class="mx-auto w-full max-w-7xl px-4 py-14 lg:px-6 lg:py-20">
      <p class="flex items-center gap-2 text-sm font-bold uppercase tracking-[0.2em] text-red-400">
        <span class="inline-block h-px w-8 bg-red-500"></span>
        Services
      </p>
      <h1 class="mt-3 max-w-3xl font-heading text-4xl font-extrabold leading-[1.08] tracking-tight drop-shadow sm:text-5xl">
        Marine construction is all we do.
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-100">
        Boat docks, seawalls, retaining walls, barge work, and beach reclamation — built for Nebraska
        lakes since 1999.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 lg:px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s, i) => (
          <a href={`/services/${s.slug}`} data-reveal style={`--reveal-delay:${i * 70}ms`} class="group relative flex flex-col overflow-hidden rounded-xl border border-ink-200 bg-white p-6 transition hover:-translate-y-1 hover:border-red-600 hover:shadow-xl">
            <span class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-red-600 transition-transform duration-300 group-hover:scale-x-100"></span>
            <span class="flex h-14 w-14 items-center justify-center rounded-lg bg-ink-950 text-red-500 transition group-hover:bg-red-600 group-hover:text-white">
              <ServiceIcon slug={s.slug} class="h-7 w-7" />
            </span>
            <h2 class="mt-5 font-heading text-xl font-bold text-ink-900">{s.cardTitle}</h2>
            <p class="mt-3 flex-1 text-ink-700">{s.cardBlurb}</p>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-bold text-red-600">Learn more <span class="transition-transform group-hover:translate-x-1">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ReviewStrip />
  <CTABlock heading="Not sure which one you need?" body="Get a straight assessment from Matt — he'll tell you what needs doing now, what can wait, and what it costs." />
</Base>
