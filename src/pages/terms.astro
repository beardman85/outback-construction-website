---
import Base from '../layouts/Base.astro';
import business from '../data/business.json';
---
<Base title="Terms of Service | Outback Construction" description="The terms that apply to your use of the Outback Construction website." canonicalPath="/terms">
  <Fragment set:html={`<!-- TODO[MATT]: general template — have this reviewed by an attorney and set the effective date before launch. -->`} />
  <section class="bg-white">
    <div class="mx-auto max-w-3xl px-4 py-16 lg:px-6">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-red-600">Terms of Service</p>
      <h1 class="mt-2 font-heading text-4xl font-extrabold tracking-tight text-ink-900">Terms of use</h1>
      <p class="mt-2 text-sm text-ink-500">Last updated: July 2026</p>

      <div class="mt-8 space-y-8 text-ink-700">
        <p>These terms apply to your use of the {business.name} website. By using this site or submitting a form, you agree to them.</p>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">Inquiries &amp; estimates</h2>
          <p class="mt-3">Submitting a form does not create a contract or guarantee a specific response time. Any pricing discussed before an on-site assessment is an estimate only. Work begins only under a separate agreement between you and Outback Construction.</p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">Use of the site</h2>
          <p class="mt-3">You agree to use this site lawfully and not to misuse our forms, disrupt the site, or attempt to access it in unauthorized ways. Content, images, and branding on this site are owned by Outback Construction or used with permission and may not be copied without consent.</p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">Disclaimer</h2>
          <p class="mt-3">This site is provided "as is." To the fullest extent permitted by law, Outback Construction is not liable for damages arising from your use of the site. These terms are governed by the laws of the State of Nebraska.</p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-bold text-ink-900">Contact us</h2>
          <p class="mt-3">
            Questions about these terms? Call
            <a href={business.telephoneHref} data-phone-cta class="ob-link">{business.telephoneDisplay}</a> or email
            <a href={`mailto:${business.email}`} class="ob-link">{business.email}</a>.
          </p>
        </div>

        <p class="text-sm text-ink-500">We may update these terms from time to time. Continued use of the site means you accept the current version.</p>
      </div>
    </div>
  </section>
</Base>
