---
import Base from '../layouts/Base.astro';
import business from '../data/business.json';

const title = 'Thank You | Outback Construction';
const description = "Got it — Matt will call you back shortly to talk through your shoreline.";
---
<Base title={title} description={description} canonicalPath="/thank-you" noindex={true}>
  <section class="bg-ink-950 text-white">
    <div class="mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center px-4 py-24 text-center lg:px-6">
      <span class="flex h-16 w-16 items-center justify-center rounded-full bg-red-600 shadow-lg">
        <svg class="h-8 w-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
      </span>
      <h1 class="mt-8 font-heading text-3xl font-extrabold tracking-tight sm:text-4xl">
        Got it — you'll hear from us soon.
      </h1>
      <p class="mt-5 max-w-xl text-lg text-ink-200">
        Matt will call you back shortly to talk through your shoreline. If it's urgent — storm
        damage, a wall actively moving — call now:
        <a href={business.telephoneHref} data-phone-cta class="font-bold text-red-500 hover:text-red-400">{business.telephoneDisplay}</a>.
      </p>
      <div class="mt-10">
        <p class="text-xs font-bold uppercase tracking-wide text-ink-500">While you wait</p>
        <div class="mt-4 flex flex-col justify-center gap-4 sm:flex-row">
          <a href="/our-work" class="rounded-md border border-white/20 px-6 py-3 text-base font-bold text-white transition hover:bg-white/10">
            See our work
          </a>
          <a href="/reviews" class="rounded-md border border-white/20 px-6 py-3 text-base font-bold text-white transition hover:bg-white/10">
            Read what neighbors say
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Backup conversion trigger: fires generate_lead on the thank-you pageview,
      covering both the JS-fetch and no-JS (server redirect) submission paths. */}
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'generate_lead' });
  </script>
</Base>
